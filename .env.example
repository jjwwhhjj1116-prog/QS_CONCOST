# 공공데이터포털의 일반 인증키(Decoding)를 입력하세요.
DATA_GO_KR_SERVICE_KEY=
LAW_API_OC=
PEXELS_API_KEY=

# 최초 관리자 계정 생성용입니다. 실제 값은 .env 또는 호스팅 Secret에만 입력하세요.
ADMIN_USERNAME=concost
ADMIN_BOOTSTRAP_PASSWORD=
APP_SECRET_KEY=

# 평일 08:30 이메일 브리핑(Resend HTTPS API)
RESEND_API_KEY=
DIGEST_FROM_EMAIL=
DIGEST_RECIPIENTS=
DIGEST_TRIGGER_TOKEN=

# 최근 몇 시간의 공고를 다시 확인할지 설정합니다. 중복은 자동 제거됩니다.
LOOKBACK_HOURS=48
DB_PATH=data/tender_radar.db
HOST=127.0.0.1
PORT=8765
